import { useEffect, useState } from "react";
import { useParams } from "react-router-dom";

import listingsApi from "../../api/listingsApi";
import { useAuth } from "../../context/AuthProvider";
import ImageSwipeCarousel from "../../components/listings/ImageSwipeCarousel";
import ListingActions from "../../components/listings/ListingActions";
import LoadingSpinner from "../../components/common/LoadingSpinner";

export default function ListingDetail() {
  const { id } = useParams();
  const { user, isAdmin } = useAuth();

  const [listing, setListing] = useState(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState("");

  useEffect(() => {
    const fetchListing = async () => {
      try {
        setLoading(true);
        const data = await listingsApi.getListingById(id);
        setListing(data);
      } catch (err) {
        console.error("İlan yüklenemedi:", err);
        setError("İlan bulunamadı.");
      } finally {
        setLoading(false);
      }
    };

    if (id) fetchListing();
  }, [id]);

  if (loading) {
    return (
      <div className="flex justify-center py-20">
        <LoadingSpinner />
      </div>
    );
  }

  if (error || !listing) {
    return (
      <div className="text-center py-20 text-gray-500">İlan bulunamadı.</div>
    );
  }

  return (
    <div className="max-w-6xl mx-auto px-4 py-6">
      {/* ÜST ALAN */}
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {/* SOL: GÖRSELLER */}
        <ImageSwipeCarousel images={listing.images} />

        {/* SAĞ: BİLGİLER */}
        <div className="flex flex-col">
          <h1 className="text-2xl font-bold mb-2">{listing.title}</h1>

          {listing.price && (
            <div className="text-2xl font-semibold text-slate-900 mb-4">
              {Number(listing.price).toLocaleString("tr-TR")} ₺
            </div>
          )}

          <div className="space-y-2 text-sm text-gray-600">
            {listing.city && <div>📍 {listing.city}</div>}
            {listing.category && <div>📦 {listing.category}</div>}
            {listing.phone && <div>📞 {listing.phone}</div>}
          </div>

          {/* FAVORİ / AKSİYONLAR */}
          <ListingActions listing={listing} />

          {/* ADMIN BİLGİSİ */}
          {isAdmin && (
            <div className="mt-4 text-sm text-red-600">Admin görünümü</div>
          )}
        </div>
      </div>

      {/* AÇIKLAMA */}
      {listing.description && (
        <div className="mt-10">
          <h2 className="text-lg font-semibold mb-2">Açıklama</h2>
          <p className="text-gray-700 whitespace-pre-line">
            {listing.description}
          </p>
        </div>
      )}
    </div>
  );
}
