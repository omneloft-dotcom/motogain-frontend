import { NavLink, useLocation } from "react-router-dom";
import { useAuth } from "../../context/AuthProvider";
import { useSocket } from "../../context/SocketProvider";
import { useEffect, useState } from "react";
import conversationsApi from "../../api/conversationsApi";
import { Icon } from "@/ui/icons/Icon";

const groupsConfig = [
  {
    title: "GENEL",
    defaultOpen: true,
    items: [
      { label: "Ana Sayfa", to: "/dashboard" },
      { label: "İlanlar", to: "/listings" },
      { label: "Duyurular", to: "/announcements" },
      { label: "Haber & Güncellemeler", to: "/news" },
    ],
  },
  {
    title: "BENİM ALANIM",
    defaultOpen: true,
    items: [
      { label: "İlanlarım", to: "/my-listings" },
      { label: "Favorilerim", to: "/favorites" },
      { label: "Mesajlar", to: "/messages" },
      { label: "Tekliflerim", to: "/offers" },
      { label: "Takvim", to: "/calendar", disabled: true },
    ],
  },
  {
    title: "TOPLULUK",
    defaultOpen: true,
    items: [
      { label: "Cordy Club", to: "/club" },
    ],
  },
  {
    title: "HESAP",
    defaultOpen: false,
    items: [
      { label: "Kişisel Bilgiler", to: "/profile" },
      { label: "Profil Ayarları", to: "/profile/settings" },
    ],
  },
];

function SidebarGroup({ title, items, isOpen, onToggle }) {
  const chevronClasses = `h-4 w-4 transition-transform ${isOpen ? "rotate-180" : ""}`;
  return (
    <div>
      <button
        onClick={onToggle}
        className="w-full flex items-center justify-between px-4 py-2 text-xs uppercase tracking-wide text-slate-400 font-semibold"
      >
        <span>{title}</span>
        <Icon
          name="chevron"
          size={16}
          className={chevronClasses}
          strokeWidth={1.5}
        />
      </button>

      {isOpen && (
        <div className="mt-1 space-y-1">
          {items.map((item) =>
            item.disabled ? (
              <div
                key={item.label}
                title="Yakında"
                className="flex items-center gap-2 px-4 py-2.5 rounded-lg text-slate-500 bg-slate-800/40 cursor-not-allowed"
                aria-disabled="true"
              >
                <span className="flex-1">{item.label}</span>
                <span className="text-[10px] font-semibold uppercase text-slate-400">
                  Coming Soon
                </span>
              </div>
            ) : (
              <NavLink key={item.label} to={item.to} className={navLinkClass}>
                {item.label}
              </NavLink>
            )
          )}
        </div>
      )}
    </div>
  );
}

const navLinkClass = ({ isActive }) =>
  [
    "block px-4 py-2.5 rounded-lg transition-colors border-l-2",
    isActive
      ? "bg-slate-800 text-white font-semibold border-indigo-400"
      : "text-slate-300 hover:bg-slate-800 hover:text-white border-transparent",
  ].join(" ");

export default function Sidebar() {
  const { user } = useAuth();
  const { socket } = useSocket();
  const location = useLocation();
  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);
  const [openGroups, setOpenGroups] = useState(() =>
    groupsConfig.reduce((acc, group) => {
      acc[group.title] = group.defaultOpen;
      return acc;
    }, {})
  );

  // unread fetch kept to avoid behavior change (reserved for future badge)
  useEffect(() => {
    let interval;
    const load = async () => {
      try {
        await conversationsApi.getConversations();
      } catch (err) {
        console.error("Unread count yüklenemedi:", err);
      }
    };
    if (user) {
      load();
      interval = setInterval(load, 20000);
    }
    return () => interval && clearInterval(interval);
  }, [user]);

  useEffect(() => {
    if (!socket) return;
    const handleInboxUpdate = () => {
      console.log("📬 Sidebar: Inbox update received");
    };
    socket.on("inbox_update", handleInboxUpdate);
    return () => {
      socket.off("inbox_update", handleInboxUpdate);
    };
  }, [socket]);

  // Close mobile menu on route change
  useEffect(() => {
    setIsMobileMenuOpen(false);
  }, [location.pathname]);

  if (!user) return null;

  const toggleGroup = (title) => {
    setOpenGroups((prev) => ({ ...prev, [title]: !prev[title] }));
  };

  const adminGroups =
    user && (user.role === "admin" || user.role === "superadmin")
      ? [
          {
            title: "ADMIN",
            defaultOpen: true,
            items: [
              { label: "Admin Dashboard", to: "/admin/dashboard" },
              { label: "Bekleyen İlanlar", to: "/admin/pending-listings" },
              { label: "İlan Detay", to: "/admin/listings" },
              { label: "Kullanıcılar", to: "/admin/users" },
              { label: "Ban Yönetimi", to: "/admin/bans" },
              { label: "Raporlar", to: "/admin/reports" },
            ],
          },
        ]
      : [];

  useEffect(() => {
    if (adminGroups.length) {
      setOpenGroups((prev) => ({
        ...prev,
        ADMIN: prev.ADMIN ?? true,
      }));
    }
  }, [adminGroups.length]);

  const sidebarContent = (
    <nav className="flex flex-col gap-4">
      {[...groupsConfig, ...adminGroups].map((group) => (
        <SidebarGroup
          key={group.title}
          title={group.title}
          items={group.items}
          isOpen={openGroups[group.title]}
          onToggle={() => toggleGroup(group.title)}
        />
      ))}
    </nav>
  );

  return (
    <>
      {/* Mobile Hamburger Button */}
      <button
        onClick={() => setIsMobileMenuOpen(!isMobileMenuOpen)}
        className="md:hidden fixed top-4 left-4 z-50 bg-slate-900 text-white p-2 rounded-lg shadow-lg"
        aria-label="Toggle menu"
      >
        <svg
          className="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          {isMobileMenuOpen ? (
            <path
              strokeLinecap="round"
              strokeLinejoin="round"
              strokeWidth={2}
              d="M6 18L18 6M6 6l12 12"
            />
          ) : (
            <path
              strokeLinecap="round"
              strokeLinejoin="round"
              strokeWidth={2}
              d="M4 6h16M4 12h16M4 18h16"
            />
          )}
        </svg>
      </button>

      {/* Mobile Overlay */}
      {isMobileMenuOpen && (
        <div
          className="md:hidden fixed inset-0 bg-black bg-opacity-50 z-40"
          onClick={() => setIsMobileMenuOpen(false)}
        />
      )}

      {/* Desktop Sidebar (always visible ≥768px) */}
      <aside className="hidden md:block w-64 bg-slate-900 text-white min-h-screen p-4">
        {sidebarContent}
      </aside>

      {/* Mobile Drawer (<768px) */}
      <aside
        className={`md:hidden fixed top-0 left-0 w-64 bg-slate-900 text-white h-full p-4 z-40 transform transition-transform duration-300 ease-in-out ${
          isMobileMenuOpen ? "translate-x-0" : "-translate-x-full"
        }`}
      >
        {sidebarContent}
      </aside>
    </>
  );
}
