# API Configuration
VITE_API_URL=http://localhost:5000

# ─────────────────────────────────────────────────────────────────
# Google OAuth Configuration (Optional - for Google Sign-In)
# ─────────────────────────────────────────────────────────────────
# REQUIRED: Google OAuth 2.0 Client ID for web application
# If not provided, Google Sign-In button will not appear on login page
#
# Setup Instructions:
# 1. Go to: https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID → Web application
# 3. Add authorized JavaScript origins:
#    - http://localhost:5173 (development)
#    - https://yourdomain.com (production)
# 4. Copy the Client ID and paste below
# 5. IMPORTANT: Backend must have the SAME client ID in:
#    GOOGLE_OAUTH_CLIENT_ID_WEB=same-client-id.apps.googleusercontent.com
#
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
