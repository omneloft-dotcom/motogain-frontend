# ════════════════════════════════════════════════════════════════════
# CORDY WEB FRONTEND — ENVIRONMENT CONFIGURATION
# ════════════════════════════════════════════════════════════════════
#
# IMPORTANT: This is an EXAMPLE file. To use it:
#
# 1. FOR LOCAL DEVELOPMENT:
#    Copy this file to .env.local (gitignored):
#      cp .env.example .env.local
#    Then edit .env.local with your local values
#
# 2. FOR PRODUCTION BUILDS:
#    Pass environment variables at build time:
#      VITE_API_URL=https://api.usecordy.com npm run build
#    Or set them in your CI/CD pipeline (GitHub Actions, etc.)
#
# 3. DO NOT commit a .env file to the repo!
#    (.env is gitignored, but be careful with .env.local, .env.production, etc.)
#
# ════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# API Configuration (REQUIRED)
# ─────────────────────────────────────────────────────────────────
# Backend API base URL (without /api/v1 suffix)
#
# LOCAL DEVELOPMENT:
VITE_API_URL=http://localhost:5000
#
# PRODUCTION (set at build time):
# VITE_API_URL=https://api.usecordy.com
#
# IMPORTANT:
# - Do NOT include /api or /api/v1 in the URL (added automatically)
# - Production builds MUST set this via build command or CI/CD
# - If missing, fallback is http://localhost:5000 (dev only)
# ─────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────
# Google OAuth Configuration (OPTIONAL)
# ─────────────────────────────────────────────────────────────────
# Google OAuth 2.0 Client ID for web application
# If not provided, Google Sign-In button will be hidden
#
# Setup Instructions:
# 1. Go to: https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID → Web application
# 3. Add authorized JavaScript origins:
#    - http://localhost:5173 (development)
#    - https://usecordy.com (production)
# 4. Copy the Client ID and paste below
# 5. IMPORTANT: Backend must have the SAME client ID in:
#    GOOGLE_OAUTH_CLIENT_ID_WEB=same-client-id.apps.googleusercontent.com
#
# LOCAL DEVELOPMENT:
VITE_GOOGLE_CLIENT_ID=
#
# PRODUCTION (set at build time):
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# ─────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────
# Firebase Cloud Messaging (OPTIONAL - for push notifications)
# ─────────────────────────────────────────────────────────────────
# If not configured, push notifications will be disabled gracefully
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_VAPID_KEY=
# ─────────────────────────────────────────────────────────────────
